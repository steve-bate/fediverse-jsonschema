{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema:as2/object",
  "$ref": "schema:as2/object-base",
  "title": "Object",
  "type": "object",
  "properties": {
    "type": {
      "oneOf": [
        {
          "$ref": "#/$defs/types"
        },
        {
          "type": "array",
          "contains": {
            "$ref": "#/$defs/types"
          }
        }
      ]
    }
  },
  "$defs": {
    "types": {
      "enum": [
        "Object",
        "Application",
        "Article",
        "Event",
        "Group",
        "Note",
        "Organization",
        "Person",
        "Service"
      ]
    }
  },
  "required": [
    "type"
  ]
}
