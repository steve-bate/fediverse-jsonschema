{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "schema:mastodon/activity-base",
  "$ref": "schema:as2/activity-base",
  "title": "Mastodon Activity",
  "type": "object",
  "properties": {
    "@context": {
      "oneOf": [
        {
          "const": "https://www.w3.org/ns/activitystreams"
        },
        {
          "type": "array",
          "contains": {
            "const": "https://www.w3.org/ns/activitystreams"
          }
        }
      ]
    }
  },
  "anyOf": [
    {
      "required": [
        "to"
      ]
    },
    {
      "required": [
        "cc"
      ]
    }
  ],
  "required": [
    "@context", "id", "type", "actor", "object"
  ]
}